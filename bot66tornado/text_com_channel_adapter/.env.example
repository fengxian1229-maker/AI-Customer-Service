APP_NAME=ai-customer-service-gateway
APP_ENV=local
APP_DEBUG=true

# Text.com / LiveChat webhook secret_key. Text.com includes this value in each webhook payload.
TEXT_COM_WEBHOOK_SECRET=replace-me

# Agent Chat API token. Used when adapter sends message by send_event.
# Docs show Authorization: Basic <your_personal_access_token> for Agent Chat Web API.
TEXT_COM_AGENT_AUTH_TOKEN=replace-me
TEXT_COM_API_BASE_URL=https://api.livechatinc.com/v3.6

# Use this to avoid processing messages sent by our own bot/agent.
# Comma-separated author ids, e.g. bot@example.com,agent@example.com
TEXT_COM_IGNORED_AUTHOR_IDS=

# Temporary tenant mapping. Later replace with DB: organization_id -> tenant_id.
DEFAULT_TENANT_ID=tenant_default
