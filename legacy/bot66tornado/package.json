{
  "name": "bot66tornado",
  "version": "0.1.0",
  "private": true,
  "description": "Clean narrow-path LiveChat Telegram bridge bot prototype",
  "main": "src/index.js",
  "scripts": {
    "test": "node tests/run-all.js",
    "smoke": "node scripts/smoke.js",
    "route:gate": "node scripts/route-gate.js",
    "batch:path-review": "node scripts/batch-path-review.js",
    "replay:real": "node scripts/replay-real-chat-report.js",
    "replay:human-seeds": "node scripts/replay-human-seed-bank.js",
    "live:sim": "node scripts/live-channel-sim.js",
    "offline:real": "node scripts/offline-real-channel-sim.js",
    "review:test-live": "node scripts/review-test-live-closure.js",
    "export:chat": "node scripts/export-chat-transcript.js",
    "export:latest-test-chat": "node scripts/export-latest-test-chat.js",
    "export:official-chat-report": "node scripts/export-official-chat-report-zh.js",
    "export:official-chat-report:pair": "node scripts/export-official-chat-report-pair.js",
    "start:test": "BOT_RUN_MODE=test BOT_DRY_RUN=true node scripts/start-bot.js --mode=test --dry-run",
    "start:test:live": "BOT_RUN_MODE=test-live BOT_DRY_RUN=false BOT_POLL_INTERVAL_MS=1000 node scripts/start-bot.js --mode=test-live --no-dry-run",
    "preflight:test:live": "node scripts/preflight-live-test.js",
    "preflight:official": "node scripts/preflight-official.js",
    "go:no-go:official": "node scripts/go-no-go-official.js",
    "postlaunch:official": "node scripts/postlaunch-official.js",
    "doctor:processes": "node scripts/doctor-processes.js",
    "doctor:conflicts": "node scripts/stop-conflicting-bots.js --dry-run",
    "doctor:telegram-token": "node scripts/doctor-telegram-token.js",
    "monitor:telegram": "node scripts/monitor-telegram-connections.js",
    "monitor:telegram:short": "TG_MONITOR_MS=60000 TG_MONITOR_INTERVAL_MS=100 node scripts/monitor-telegram-connections.js",
    "stop:conflicts": "node scripts/stop-conflicting-bots.js",
    "status:test:live": "node scripts/status-bot.js --mode=test-live",
    "stop:test:live": "node scripts/stop-bot.js --mode=test-live",
    "watch:test:live": "BOT_RUN_MODE=test-live BOT_DRY_RUN=false BOT_POLL_INTERVAL_MS=1000 node scripts/watch-bot.js --mode=test-live",
    "status:test": "node scripts/status-bot.js --mode=test",
    "stop:test": "node scripts/stop-bot.js --mode=test",
    "start:official": "BOT_RUN_MODE=official BOT_CONFIRM_OFFICIAL=YES BOT_POLL_INTERVAL_MS=1000 node scripts/start-bot.js --mode=official --no-dry-run",
    "watch:official": "BOT_RUN_MODE=official BOT_CONFIRM_OFFICIAL=YES BOT_POLL_INTERVAL_MS=1000 node scripts/watch-bot.js --mode=official",
    "status:official": "node scripts/status-bot.js --mode=official",
    "status:official:now": "BOT_STATUS_RECENT_MS=60000 node scripts/status-bot.js --mode=official",
    "health:official": "node scripts/status-bot.js --mode=official --require-running --strict",
    "launchd:install:official": "node scripts/launchd-official.js install",
    "launchd:uninstall:official": "node scripts/launchd-official.js uninstall",
    "launchd:status:official": "node scripts/launchd-official.js status",
    "stop:official": "node scripts/stop-bot.js --mode=official"
  },
  "engines": {
    "node": ">=18"
  }
}
